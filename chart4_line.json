{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Average Monthly Rainfall by City",
    "fontSize": 16,
    "font": "Georgia",
    "anchor": "start"
  },
  "width": 650,
  "height": 380,
  "data": { "url": "data/monthly_rainfall.csv" },
  "layer": [
    {
      "mark": { "type": "line", "strokeWidth": 2.5 },
      "encoding": {
        "x": {
          "field": "month_num",
          "type": "ordinal",
          "axis": {
            "title": "Month",
            "labelExpr": "['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][datum.value - 1]"
          }
        },
        "y": {
          "field": "avg_rainfall_mm",
          "type": "quantitative",
          "axis": { "title": "Average Rainfall (mm)" }
        },
        "color": {
          "field": "city",
          "type": "nominal",
          "title": "City",
          "scale": {
            "domain": ["Sydney","Melbourne","Brisbane","Darwin","Perth","Adelaide"],
            "range": ["#1f77b4","#e377c2","#ff7f0e","#d62728","#9467bd","#8c564b"]
          }
        }
      }
    },
    {
      "mark": { "type": "point", "size": 60, "filled": true },
      "encoding": {
        "x": { "field": "month_num", "type": "ordinal" },
        "y": { "field": "avg_rainfall_mm", "type": "quantitative" },
        "color": { "field": "city", "type": "nominal" },
        "tooltip": [
          { "field": "city", "type": "nominal", "title": "City" },
          { "field": "month", "type": "nominal", "title": "Month" },
          { "field": "avg_rainfall_mm", "type": "quantitative", "title": "Avg Rainfall (mm)", "format": ".1f" }
        ]
      }
    }
  ]
}